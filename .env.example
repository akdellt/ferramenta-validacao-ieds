# BANCO DE DADOS (POSTGRESQL)
POSTGRES_USER=admin
POSTGRES_PASSWORD=sua_senha_aqui
POSTGRES_DB=equatorial_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://admin:sua_senha_aqui@db:5432/equatorial_db

# USUÁRIO MESTRE
MASTER_USER_REGISTRATION=A111
MASTER_USER_NAME=Equatorial Mestre
MASTER_USER_PASSWORD=crie_senha_aqui

# CONFIGURAÇÕES DO COFRE DE SENHAS (VAULT)
VAULT_API_URL=https://vault-real-da-empresa.com/api
VAULT_CLIENT_ID=id_real
VAULT_CLIENT_SECRET=chave_real
VAULT_AUTH_ENDPOINT=/api/v1/auth/token
VAULT_SECRET_ENDPOINT=/api/v1/secrets
